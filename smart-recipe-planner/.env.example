# Vercel AI Gateway — used by api/analyze.ts to call Claude (with a GPT-4o fallback)
VERCEL_AI_GATEWAY_API_KEY=

# Supabase — used by api/analyze.ts and api/recipe.ts to cache/read recipes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Unsplash — used by api/analyze.ts to fetch a photo per generated recipe
UNSPLASH_ACCESS_KEY=

# URL of the backend the Expo app talks to.
# Local dev: run `vercel dev` and leave this unset (defaults to http://localhost:3000).
# Production/preview: set to the deployed Vercel URL.
EXPO_PUBLIC_API_URL=
